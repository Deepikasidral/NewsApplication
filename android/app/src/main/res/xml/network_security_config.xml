<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration - use system certificates -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Allow cleartext traffic ONLY for your backend server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">13.51.242.86</domain>
    </domain-config>
</network-security-config>
